PORT=8085
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=trainforge

CORS_ORIGIN=http://localhost:5173

JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=14

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TrainForge <no-reply@trainforge.local>
MAIL_NOTIFY_TO=

ACTIVATION_TOKEN_EXPIRES_MINUTES=20
EXPOSE_ACTIVATION_TOKEN=true

