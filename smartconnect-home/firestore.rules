rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
      allow update: if isAdmin() || request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /devices/{deviceId} {
      allow read: if isAdmin() || (signedIn() && resource.data.assignedTo == request.auth.uid);
      allow write: if isAdmin();
    }

    match /packs/{packId} {
      allow read: if isAdmin() ||
        (signedIn() &&
          (!('assignedTo' in resource.data) ||
            resource.data.assignedTo.hasAny([request.auth.uid, 'all'])));
      allow write: if isAdmin();
    }

    match /warranties/{warrantyId} {
      allow read: if isAdmin() ||
        (signedIn() &&
          get(/databases/$(database)/documents/devices/$(resource.data.deviceId)).data.assignedTo == request.auth.uid);
      allow write: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.createdBy == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow create: if signedIn() && request.resource.data.actorId == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.actorId == request.auth.uid);
    }
  }
}
